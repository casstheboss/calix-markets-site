<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Calix Markets — Market Infrastructure for Tokenized Assets</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,300;12..96,400;12..96,500;12..96,600;12..96,700;12..96,800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />

<style>
/* ─── TOKENS ─── */
:root {
  --teal: #3ECFAD;
  --teal-dim: rgba(62,207,173,0.12);
  --teal-mid: rgba(62,207,173,0.25);

  /* DARK */
  --bg:         #060A07;
  --bg-card:    #0D1210;
  --bg-raised:  #111915;
  --border:     rgba(255,255,255,0.07);
  --border-mid: rgba(255,255,255,0.12);
  --text:        #F0F5F2;
  --text-muted:  #7A9088;
  --text-dim:    #3E5049;
  --nav-bg:      rgba(6,10,7,0.85);
}
[data-theme="light"] {
  --bg:         #F5F8F6;
  --bg-card:    #FFFFFF;
  --bg-raised:  #EBF0EC;
  --border:     rgba(0,0,0,0.07);
  --border-mid: rgba(0,0,0,0.12);
  --text:        #0C1410;
  --text-muted:  #4A6058;
  --text-dim:    #9AB0A8;
  --nav-bg:      rgba(245,248,246,0.88);
}

/* ─── RESET ─── */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{
  font-family:'DM Sans',sans-serif;
  background:var(--bg);
  color:var(--text);
  line-height:1.6;
  overflow-x:hidden;
  transition:background .35s,color .35s;
}
img{display:block;max-width:100%}
a{color:inherit;text-decoration:none}
button{cursor:pointer;border:none;background:none;font:inherit;color:inherit}

/* ─── GRAIN OVERLAY ─── */
body::before{
  content:'';
  position:fixed;inset:0;
  pointer-events:none;z-index:999;
  opacity:.028;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
  background-size:200px 200px;
}
[data-theme="light"] body::before{opacity:.018}

/* ─── TYPOGRAPHY ─── */
.display{
  font-family:'Bricolage Grotesque',sans-serif;
  font-weight:800;
  letter-spacing:-0.03em;
  line-height:1.02;
}
.mono{font-family:'DM Mono',monospace;font-size:.75rem;letter-spacing:.08em}

/* ─── LOGO ─── */
.logo-mark{height:36px;width:36px;flex-shrink:0;border-radius:8px;overflow:hidden}
.logo-mark-sm{height:28px;width:28px;flex-shrink:0;border-radius:7px;overflow:hidden}
.logo-text{
  font-family:'Bricolage Grotesque',sans-serif;
  font-weight:700;font-size:1.05rem;
  letter-spacing:-0.02em;
  color:var(--text);
}
.logo-text-sm{
  font-family:'Bricolage Grotesque',sans-serif;
  font-weight:700;font-size:.9rem;
  letter-spacing:-0.02em;
  color:var(--text);
}

/* ─── NAV ─── */
nav{
  position:fixed;top:0;left:0;right:0;z-index:100;
  display:flex;align-items:center;justify-content:space-between;
  padding:.9rem 2.5rem;
  background:var(--nav-bg);
  backdrop-filter:blur(18px);
  border-bottom:1px solid var(--border);
  transition:background .35s,border-color .35s;
}
.nav-logo{display:flex;align-items:center;gap:.7rem}
.nav-logo img{height:34px;width:auto}
.nav-links{display:flex;gap:2rem;align-items:center}
.nav-links a{
  font-size:.88rem;font-weight:500;
  color:var(--text-muted);
  transition:color .2s;
}
.nav-links a:hover{color:var(--text)}
.nav-right{display:flex;align-items:center;gap:1rem}
.btn-cta{
  display:inline-flex;align-items:center;gap:.4rem;
  padding:.55rem 1.25rem;
  background:var(--teal);
  color:#060A07;
  font-size:.85rem;font-weight:600;
  border-radius:6px;
  transition:opacity .2s,transform .15s;
}
.btn-cta:hover{opacity:.88;transform:translateY(-1px)}
.theme-toggle{
  width:36px;height:36px;
  border-radius:8px;
  border:1px solid var(--border-mid);
  display:grid;place-items:center;
  color:var(--text-muted);
  transition:color .2s,border-color .2s,background .35s;
}
.theme-toggle:hover{color:var(--text);border-color:var(--border-mid)}
.icon-sun,.icon-moon{width:16px;height:16px;stroke:currentColor;fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}
[data-theme="dark"] .icon-sun{display:none}
[data-theme="light"] .icon-moon{display:none}

/* ─── HERO ─── */
.hero{
  min-height:100vh;
  display:flex;flex-direction:column;
  align-items:flex-start;justify-content:center;
  padding:10rem 2.5rem 5rem;
  position:relative;overflow:hidden;
}
.hero-eyebrow{
  display:inline-flex;align-items:center;gap:.5rem;
  padding:.3rem .9rem;
  border:1px solid var(--teal-mid);
  border-radius:100px;
  background:var(--teal-dim);
  color:var(--teal);
  font-size:.76rem;font-weight:500;letter-spacing:.06em;text-transform:uppercase;
  margin-bottom:2rem;
}
.hero-eyebrow span{width:5px;height:5px;border-radius:50%;background:var(--teal);display:block}
.hero h1{
  font-family:'Bricolage Grotesque',sans-serif;
  font-weight:800;
  font-size:clamp(3.2rem,7vw,7.5rem);
  letter-spacing:-0.04em;
  line-height:1.0;
  max-width:14ch;
  margin-bottom:1.75rem;
}
.hero h1 em{
  font-style:normal;
  color:var(--teal);
}
.hero-sub{
  font-size:clamp(1rem,1.6vw,1.2rem);
  color:var(--text-muted);
  max-width:46ch;
  line-height:1.7;
  margin-bottom:2.5rem;
  font-weight:300;
}
.hero-actions{display:flex;gap:1rem;flex-wrap:wrap}
.btn-outline{
  display:inline-flex;align-items:center;gap:.4rem;
  padding:.65rem 1.4rem;
  border:1px solid var(--border-mid);
  border-radius:6px;
  font-size:.9rem;font-weight:500;
  color:var(--text-muted);
  transition:color .2s,border-color .2s;
}
.btn-outline:hover{color:var(--text);border-color:var(--teal)}
.btn-primary{
  display:inline-flex;align-items:center;gap:.5rem;
  padding:.65rem 1.6rem;
  background:var(--teal);
  color:#060A07;
  font-size:.9rem;font-weight:600;
  border-radius:6px;
  transition:opacity .2s,transform .15s;
}
.btn-primary:hover{opacity:.88;transform:translateY(-1px)}

/* Hero canvas - full bleed background */
#hero-canvas{
  position:absolute;inset:0;
  width:100%;height:100%;
  opacity:1;
  pointer-events:none;
  z-index:0;
}
/* Always dark overlay for readability */
.hero-overlay{
  position:absolute;inset:0;
  background:linear-gradient(105deg,rgba(4,12,6,0.82) 0%,rgba(4,12,6,0.55) 55%,rgba(4,12,6,0.2) 100%);
  z-index:1;
  pointer-events:none;
}
/* Force white text in hero regardless of theme */
.hero,.hero *:not(.btn-primary){color:#fff !important}
.hero .hero-sub{color:rgba(255,255,255,0.72) !important}
.hero .btn-outline{border-color:rgba(255,255,255,0.3) !important;color:rgba(255,255,255,0.8) !important}
.hero .btn-outline:hover{border-color:var(--teal) !important;color:#fff !important}
.hero .hero-eyebrow{color:var(--teal) !important}
.hero > *:not(#hero-canvas):not(.hero-overlay){position:relative;z-index:2}

/* ─── MARQUEE ─── */
.marquee-section{
  border-top:1px solid var(--border);
  border-bottom:1px solid var(--border);
  padding:1.25rem 0;
  overflow:hidden;
}
.marquee-label{
  text-align:center;
  font-size:.72rem;letter-spacing:.12em;text-transform:uppercase;
  color:var(--text-dim);
  margin-bottom:1rem;
  font-weight:500;
}
.marquee-track{
  display:flex;
  animation:marquee 28s linear infinite;
  width:max-content;
}
.marquee-track:hover{animation-play-state:paused}
.marquee-item{
  display:flex;align-items:center;
  padding:0 2.5rem;
  font-family:'Bricolage Grotesque',sans-serif;
  font-weight:600;
  font-size:1.1rem;
  color:var(--text-muted);
  white-space:nowrap;
  transition:color .2s;
}
.marquee-item::after{
  content:'';
  width:4px;height:4px;
  border-radius:50%;
  background:var(--teal);
  margin-left:2.5rem;
  opacity:.5;
}
@keyframes marquee{from{transform:translateX(0)}to{transform:translateX(-50%)}}

/* ─── SECTIONS ─── */
section{padding:6rem 2.5rem}
.section-label{
  display:inline-flex;align-items:center;gap:.5rem;
  color:var(--teal);
  font-size:.72rem;font-weight:600;letter-spacing:.14em;text-transform:uppercase;
  margin-bottom:1rem;
}
.section-label::before{
  content:'';width:20px;height:1px;background:var(--teal);
}
.section-title{
  font-family:'Bricolage Grotesque',sans-serif;
  font-weight:800;
  font-size:clamp(2rem,4vw,3.5rem);
  letter-spacing:-0.03em;
  line-height:1.05;
  max-width:18ch;
  margin-bottom:1.25rem;
}
.section-sub{
  color:var(--text-muted);
  max-width:52ch;
  line-height:1.75;
  font-size:1rem;
  font-weight:300;
}

/* ─── HOW IT WORKS ─── */
.steps-grid{
  margin-top:4rem;
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
  gap:1.5px;
  background:var(--border);
  border:1px solid var(--border);
  border-radius:12px;
  overflow:hidden;
}
.step{
  background:var(--bg-card);
  padding:2.25rem 2rem;
  display:flex;flex-direction:column;gap:1rem;
  transition:background .2s;
}
.step:hover{background:var(--bg-raised)}
.step-num{
  font-family:'DM Mono',monospace;
  font-size:.75rem;letter-spacing:.1em;
  color:var(--teal);
  font-weight:500;
}
.step h3{
  font-family:'Bricolage Grotesque',sans-serif;
  font-weight:700;font-size:1.35rem;
  letter-spacing:-0.02em;
}
.step p{color:var(--text-muted);font-size:.92rem;line-height:1.7;font-weight:300}
.step-icon{
  width:38px;height:38px;
  border-radius:9px;
  background:var(--teal-dim);
  border:1px solid var(--teal-mid);
  display:grid;place-items:center;
  margin-bottom:.25rem;
}
.step-icon svg{width:17px;height:17px;stroke:var(--teal);fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}



/* ─── USE CASES ─── */
.use-cases-grid{
  margin-top:4rem;
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(320px,1fr));
  gap:1.25rem;
}
.use-case{
  background:var(--bg-card);
  border:1px solid var(--border);
  border-radius:12px;
  padding:2.5rem 2rem;
  display:flex;flex-direction:column;gap:1rem;
  transition:border-color .25s,transform .2s,background .2s;
}
.use-case:hover{
  border-color:var(--teal-mid);
  transform:translateY(-3px);
  background:var(--bg-raised);
}
.uc-label{
  font-family:'DM Mono',monospace;
  font-size:.68rem;letter-spacing:.1em;text-transform:uppercase;
  color:var(--teal);font-weight:500;
}
.use-case h3{
  font-family:'Bricolage Grotesque',sans-serif;
  font-weight:700;font-size:1.3rem;
  letter-spacing:-0.02em;
  line-height:1.15;
}
.use-case p{color:var(--text-muted);font-size:.9rem;line-height:1.75;font-weight:300;flex:1}
.uc-tags{display:flex;flex-wrap:wrap;gap:.5rem;margin-top:.5rem}
.uc-tag{
  padding:.2rem .7rem;
  border:1px solid var(--border-mid);
  border-radius:100px;
  font-size:.72rem;font-weight:500;
  color:var(--text-muted);
}

/* ─── PHILOSOPHY TWO-COL ─── */
.philosophy-two-col{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:5rem;
  align-items:start;
}
.philosophy-left{}
.philosophy-left blockquote{
  font-family:'Bricolage Grotesque',sans-serif;
  font-weight:600;
  font-size:clamp(1.2rem,2vw,1.8rem);
  letter-spacing:-0.02em;
  line-height:1.3;
  color:var(--text);
  border-left:3px solid var(--teal);
  padding-left:1.5rem;
  margin:2rem 0;
}
.philosophy-left p{
  color:var(--text-muted);
  font-size:.95rem;line-height:1.85;font-weight:300;
  margin-bottom:1.1rem;
}
.philosophy-right{}
.cta-sticky{
  position:sticky;
  top:6rem;
  background:var(--bg-card);
  border:1px solid var(--border);
  border-radius:14px;
  padding:2.5rem;
  display:flex;flex-direction:column;gap:1.25rem;
}
.cta-heading{
  font-family:'Bricolage Grotesque',sans-serif;
  font-weight:800;
  font-size:clamp(1.6rem,2.5vw,2.2rem);
  letter-spacing:-0.03em;
  line-height:1.1;
}
.cta-sub{
  color:var(--text-muted);
  font-size:.9rem;line-height:1.75;font-weight:300;
}
.cta-buttons{display:flex;gap:.75rem;flex-wrap:wrap}

@media(max-width:900px){
  .philosophy-two-col{grid-template-columns:1fr;gap:3rem}
  .cta-sticky{position:static}
}

/* ─── PHILOSOPHY (keep old vars used elsewhere) ─── */
.philosophy{
  background:var(--bg-raised);
  border-top:1px solid var(--border);
  border-bottom:1px solid var(--border);
}
.philosophy-inner{
  max-width:800px;
}
.philosophy blockquote{
  font-family:'Bricolage Grotesque',sans-serif;
  font-weight:600;
  font-size:clamp(1.4rem,2.5vw,2.1rem);
  letter-spacing:-0.02em;
  line-height:1.3;
  color:var(--text);
  border-left:3px solid var(--teal);
  padding-left:1.75rem;
  margin:2.5rem 0;
}
.philosophy p{
  color:var(--text-muted);
  font-size:1rem;line-height:1.85;font-weight:300;
  margin-bottom:1.25rem;
}
.philosophy-contact{
  display:flex;flex-wrap:wrap;gap:1rem;
  margin-top:2.5rem;
  padding-top:2rem;
  border-top:1px solid var(--border);
}
.contact-item{
  display:flex;align-items:center;gap:.6rem;
  padding:.65rem 1.2rem;
  border:1px solid var(--border-mid);
  border-radius:8px;
  font-size:.85rem;font-weight:500;
  color:var(--text-muted);
  transition:color .2s,border-color .2s;
}
.contact-item:hover{color:var(--teal);border-color:var(--teal-mid)}
.contact-item svg{width:15px;height:15px;stroke:currentColor;fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;flex-shrink:0}

/* ─── BENCHMARKS ─── */
.benchmarks-row{
  margin-top:4rem;
  display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));
  gap:1px;background:var(--border);
  border:1px solid var(--border);border-radius:12px;overflow:hidden;
}
.bench{
  background:var(--bg-card);
  padding:2rem 1.75rem;
  text-align:center;
  transition:background .2s;
}
.bench:hover{background:var(--bg-raised)}
.bench-val{
  font-family:'Bricolage Grotesque',sans-serif;
  font-weight:800;font-size:2.5rem;
  letter-spacing:-0.04em;
  color:var(--teal);
  line-height:1;margin-bottom:.4rem;
}
.bench-label{font-size:.82rem;color:var(--text-muted);font-weight:400}

/* ─── FOOTER ─── */
footer{
  padding:2rem 2.5rem;
  border-top:1px solid var(--border);
  display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;
}
.footer-logo{display:flex;align-items:center;gap:.6rem}
.footer-logo img{height:26px}
.footer-copy{font-size:.8rem;color:var(--text-dim)}

/* ─── ANIMATIONS ─── */
.reveal{
  opacity:0;transform:translateY(28px);
  transition:opacity .7s ease,transform .7s ease;
}
.reveal.visible{opacity:1;transform:none}
.reveal-delay-1{transition-delay:.1s}
.reveal-delay-2{transition-delay:.2s}
.reveal-delay-3{transition-delay:.3s}
.reveal-delay-4{transition-delay:.4s}

/* ─── RESPONSIVE ─── */
@media(max-width:768px){
  nav{padding:.8rem 1.25rem}
  .nav-links{display:none}
  .hero{padding:8rem 1.25rem 4rem}
  section{padding:4rem 1.25rem}
  .steps-grid,.modules-grid,.benchmarks-row{grid-template-columns:1fr}
  .use-cases-grid{grid-template-columns:1fr}
  #hero-canvas{display:none}
  footer{flex-direction:column;align-items:flex-start}
  .philosophy-contact{flex-direction:column}
}
</style>
</head>
