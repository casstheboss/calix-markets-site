<script data-cfasync="false" src="/cdn-cgi/scripts/5c5dd728/cloudflare-static/email-decode.min.js"></script><script>
/* ─── THEME TOGGLE ─── */
const html = document.documentElement;
const btn = document.getElementById('themeToggle');
btn.addEventListener('click', () => {
  html.dataset.theme = html.dataset.theme === 'dark' ? 'light' : 'dark';
});

/* ─── MARQUEE ─── */
const exchanges = ['Binance','OKX','Upbit','ByBit','Bitget','Gate.io','KuCoin','MEXC','Bitfinex','BingX','Kraken','Bithumb','HTX','Coinbase'];
const track = document.getElementById('marqueeTrack');
// Duplicate for seamless loop
[...exchanges, ...exchanges].forEach(name => {
  const el = document.createElement('div');
  el.className = 'marquee-item';
  el.textContent = name;
  track.appendChild(el);
});

/* ─── HERO CANVAS — TOUCAN + CHARTS ─── */
const canvas = document.getElementById('hero-canvas');
const ctx = canvas.getContext('2d');
let W, H;

// ── Candlestick data ──
const CANDLES = 60;
let candles = [];
let priceHistory = [];
let frameCount = 0;

function genCandle(prev) {
  const open = prev ? prev.close : 100 + Math.random()*40;
  const move = (Math.random()-0.46)*4.5;
  const close = open + move;
  const high = Math.max(open,close) + Math.random()*3;
  const low  = Math.min(open,close) - Math.random()*3;
  const vol  = 0.3 + Math.random()*0.7;
  return {open,close,high,low,vol};
}

function initCandles() {
  candles = [];
  for(let i=0;i<CANDLES;i++) candles.push(genCandle(candles[i-1]));
  priceHistory = candles.map(c=>c.close);
}

function resize() {
  const hero = canvas.parentElement;
  W = hero.offsetWidth || window.innerWidth;
  H = hero.offsetHeight || window.innerHeight;
  canvas.width = W * devicePixelRatio;
  canvas.height = H * devicePixelRatio;
  ctx.scale(devicePixelRatio, devicePixelRatio);
  initCandles();
}

// ── Draw toucan ──
function drawToucan(cx, cy, sc) {
  // Branch
  ctx.save();
  ctx.beginPath();
  ctx.moveTo(cx-55*sc, cy+82*sc); ctx.lineTo(cx+65*sc, cy+82*sc);
  ctx.strokeStyle='rgba(60,40,15,0.7)'; ctx.lineWidth=9*sc; ctx.lineCap='round'; ctx.stroke();

  // Body
  ctx.beginPath();
  ctx.ellipse(cx+5*sc, cy+32*sc, 42*sc, 50*sc, -0.08, 0, Math.PI*2);
  ctx.fillStyle='rgba(15,15,15,0.88)'; ctx.fill();

  // White chest
  ctx.beginPath();
  ctx.ellipse(cx+14*sc, cy+18*sc, 20*sc, 28*sc, 0.15, 0, Math.PI*2);
  ctx.fillStyle='rgba(245,240,220,0.92)'; ctx.fill();

  // Teal chest band
  ctx.beginPath();
  ctx.ellipse(cx+15*sc, cy+44*sc, 18*sc, 8*sc, 0.1, 0, Math.PI*2);
  ctx.fillStyle='rgba(62,207,173,0.85)'; ctx.fill();

  // Head
  ctx.beginPath();
  ctx.arc(cx+18*sc, cy-28*sc, 30*sc, 0, Math.PI*2);
  ctx.fillStyle='rgba(12,12,12,0.9)'; ctx.fill();

  // Beak — lower jaw (yellow-orange)
  ctx.beginPath();
  ctx.moveTo(cx+42*sc, cy-18*sc);
  ctx.bezierCurveTo(cx+115*sc,cy-8*sc,  cx+130*sc,cy+8*sc,  cx+90*sc,cy+18*sc);
  ctx.bezierCurveTo(cx+80*sc, cy+14*sc, cx+55*sc, cy+2*sc,  cx+42*sc, cy-8*sc);
  ctx.closePath();
  ctx.fillStyle='rgba(235,185,55,0.95)'; ctx.fill();

  // Beak — upper jaw (green to yellow)
  const beakGrad = ctx.createLinearGradient(cx+42*sc,0,cx+130*sc,0);
  beakGrad.addColorStop(0,'rgba(90,175,60,0.95)');
  beakGrad.addColorStop(0.5,'rgba(160,200,50,0.9)');
  beakGrad.addColorStop(1,'rgba(235,185,55,0.9)');
  ctx.beginPath();
  ctx.moveTo(cx+42*sc, cy-18*sc);
  ctx.bezierCurveTo(cx+115*sc,cy-32*sc, cx+132*sc,cy-12*sc, cx+90*sc,cy+4*sc);
  ctx.bezierCurveTo(cx+80*sc, cy-2*sc,  cx+55*sc, cy-12*sc, cx+42*sc,cy-18*sc);
  ctx.closePath();
  ctx.fillStyle=beakGrad; ctx.fill();

  // Beak ridge line
  ctx.beginPath();
  ctx.moveTo(cx+42*sc, cy-18*sc);
  ctx.bezierCurveTo(cx+115*sc,cy-20*sc, cx+128*sc,cy-10*sc, cx+90*sc,cy+10*sc);
  ctx.strokeStyle='rgba(80,50,0,0.3)'; ctx.lineWidth=1.5*sc; ctx.stroke();

  // Eye ring
  ctx.beginPath();
  ctx.arc(cx+34*sc, cy-36*sc, 9*sc, 0, Math.PI*2);
  ctx.fillStyle='rgba(62,207,173,0.7)'; ctx.fill();

  // Eye white
  ctx.beginPath();
  ctx.arc(cx+34*sc, cy-36*sc, 7*sc, 0, Math.PI*2);
  ctx.fillStyle='rgba(245,245,245,1)'; ctx.fill();

  // Pupil
  ctx.beginPath();
  ctx.arc(cx+35*sc, cy-36*sc, 4*sc, 0, Math.PI*2);
  ctx.fillStyle='#050f07'; ctx.fill();

  // Eye highlight
  ctx.beginPath();
  ctx.arc(cx+33*sc, cy-38*sc, 1.5*sc, 0, Math.PI*2);
  ctx.fillStyle='rgba(255,255,255,0.9)'; ctx.fill();

  // Tail feathers
  ctx.beginPath();
  ctx.moveTo(cx-32*sc, cy+50*sc);
  ctx.bezierCurveTo(cx-70*sc,cy+55*sc, cx-75*sc,cy+75*sc, cx-55*sc,cy+80*sc);
  ctx.bezierCurveTo(cx-80*sc,cy+70*sc, cx-80*sc,cy+50*sc, cx-32*sc,cy+48*sc);
  ctx.fillStyle='rgba(15,15,15,0.85)'; ctx.fill();

  // Feet
  [cx-8*sc, cx+16*sc].forEach(fx=>{
    ctx.beginPath();
    ctx.moveTo(fx, cy+79*sc);
    ctx.lineTo(fx-12*sc, cy+89*sc);
    ctx.moveTo(fx, cy+79*sc);
    ctx.lineTo(fx, cy+91*sc);
    ctx.moveTo(fx, cy+79*sc);
    ctx.lineTo(fx+10*sc, cy+87*sc);
    ctx.strokeStyle='rgba(60,40,15,0.75)';
    ctx.lineWidth=3.5*sc; ctx.lineCap='round'; ctx.stroke();
  });

  ctx.restore();
}

// ── Draw charts ──
function drawCharts() {
  const chartX = 30, chartY = H*0.18;
  const chartW = W*0.52, chartH = H*0.48;

  // Grid
  ctx.save();
  for(let i=0;i<=5;i++){
    const y = chartY + (chartH/5)*i;
    ctx.beginPath(); ctx.moveTo(chartX,y); ctx.lineTo(chartX+chartW,y);
    ctx.strokeStyle='rgba(62,207,173,0.08)'; ctx.lineWidth=1; ctx.stroke();
  }
  for(let i=0;i<=8;i++){
    const x = chartX + (chartW/8)*i;
    ctx.beginPath(); ctx.moveTo(x,chartY); ctx.lineTo(x,chartY+chartH);
    ctx.strokeStyle='rgba(62,207,173,0.06)'; ctx.lineWidth=1; ctx.stroke();
  }
  ctx.restore();

  // Price range
  const allPrices = candles.flatMap(c=>[c.high,c.low]);
  const minP = Math.min(...allPrices)-2, maxP = Math.max(...allPrices)+2;
  const priceRange = maxP - minP;
  const toY = p => chartY + chartH - ((p-minP)/priceRange)*chartH;
  const candleW = (chartW/CANDLES)*0.72;
  const gap     = (chartW/CANDLES);

  // Volume bars
  ctx.save();
  candles.forEach((c,i)=>{
    const x = chartX + i*gap;
    const isUp = c.close>=c.open;
    ctx.fillStyle = isUp ? 'rgba(62,207,173,0.15)' : 'rgba(255,90,90,0.12)';
    const volH = c.vol * (chartH*0.18);
    ctx.fillRect(x, chartY+chartH-volH, candleW, volH);
  });
  ctx.restore();

  // Candles
  ctx.save();
  candles.forEach((c,i)=>{
    const x = chartX + i*gap + candleW*0.5 - 0.5;
    const isUp = c.close>=c.open;
    const col = isUp ? 'rgba(62,207,173,0.9)' : 'rgba(255,90,90,0.85)';
    // Wick
    ctx.beginPath();
    ctx.moveTo(x, toY(c.high)); ctx.lineTo(x, toY(c.low));
    ctx.strokeStyle=col; ctx.lineWidth=1.2; ctx.stroke();
    // Body
    const bodyTop = toY(Math.max(c.open,c.close));
    const bodyBot = toY(Math.min(c.open,c.close));
    const bodyH = Math.max(1.5, bodyBot-bodyTop);
    ctx.fillStyle=col;
    ctx.fillRect(chartX+i*gap, bodyTop, candleW, bodyH);
  });
  ctx.restore();

  // Price line (smooth)
  ctx.save();
  ctx.beginPath();
  priceHistory.forEach((p,i)=>{
    const x = chartX + i*gap + candleW/2;
    const y = toY(p);
    i===0 ? ctx.moveTo(x,y) : ctx.lineTo(x,y);
  });
  ctx.strokeStyle='rgba(62,207,173,0.55)'; ctx.lineWidth=1.5;
  ctx.setLineDash([4,4]); ctx.stroke(); ctx.setLineDash([]);

  // Glow on last price
  const lastX = chartX+(candles.length-1)*gap+candleW/2;
  const lastY = toY(priceHistory[priceHistory.length-1]);
  const pulse = Math.sin(frameCount*0.05)*0.5+0.5;
  ctx.beginPath();
  ctx.arc(lastX,lastY,4+pulse*3,0,Math.PI*2);
  ctx.fillStyle=`rgba(62,207,173,${0.2+pulse*0.3})`; ctx.fill();
  ctx.beginPath();
  ctx.arc(lastX,lastY,3,0,Math.PI*2);
  ctx.fillStyle='rgba(62,207,173,1)'; ctx.fill();

  // Price label
  const lastPrice = priceHistory[priceHistory.length-1];
  ctx.fillStyle='rgba(62,207,173,1)';
  ctx.font=`500 11px 'DM Mono', monospace`;
  ctx.fillText(lastPrice.toFixed(2), lastX+8, lastY+4);

  ctx.restore();

  // Chart labels
  ctx.save();
  ctx.fillStyle='rgba(255,255,255,0.25)';
  ctx.font=`400 10px 'DM Mono', monospace`;
  ctx.fillText('CALIX / USD', chartX, chartY-10);
  ctx.fillStyle='rgba(62,207,173,0.6)';
  ctx.fillText('LIVE', chartX+80, chartY-10);
  ctx.restore();
}

// ── Firefly nodes ──
let nodes = [];
function initNodes() {
  nodes = Array.from({length:14},()=>({
    x:Math.random()*W, y:Math.random()*H,
    vx:(Math.random()-.5)*.3, vy:(Math.random()-.5)*.3,
    r:Math.random()*1.8+.8, pulse:Math.random()*Math.PI*2
  }));
}

function drawFrame() {
  frameCount++;
  ctx.clearRect(0,0,W,H);

  // Background
  const bgGrad = ctx.createLinearGradient(0,0,W,H);
  bgGrad.addColorStop(0,'#04100A');
  bgGrad.addColorStop(0.5,'#061209');
  bgGrad.addColorStop(1,'#040d07');
  ctx.fillStyle=bgGrad;
  ctx.fillRect(0,0,W,H);

  // Subtle radial glow center-right
  const glow = ctx.createRadialGradient(W*.7,H*.4,0,W*.7,H*.4,W*.55);
  glow.addColorStop(0,'rgba(62,207,173,0.06)');
  glow.addColorStop(1,'transparent');
  ctx.fillStyle=glow; ctx.fillRect(0,0,W,H);

  // Toucan (right side)
  if(W>600) {
    const toucanX = W*0.78, toucanY = H*0.46, toucanSc = Math.min(H/600, W/900)*1.1;
    drawToucan(toucanX, toucanY, toucanSc);
  }

  // Charts (left/center)
  drawCharts();

  // Floating nodes
  nodes.forEach(n=>{
    n.x+=n.vx; n.y+=n.vy; n.pulse+=.012;
    if(n.x<0||n.x>W) n.vx*=-1;
    if(n.y<0||n.y>H) n.vy*=-1;
  });
  for(let i=0;i<nodes.length;i++){
    for(let j=i+1;j<nodes.length;j++){
      const a=nodes[i],b=nodes[j];
      const d=Math.hypot(a.x-b.x,a.y-b.y);
      if(d<160){
        ctx.beginPath(); ctx.moveTo(a.x,a.y); ctx.lineTo(b.x,b.y);
        ctx.strokeStyle=`rgba(62,207,173,${(1-d/160)*.12})`; ctx.lineWidth=.7; ctx.stroke();
      }
    }
  }
  nodes.forEach(n=>{
    const p=Math.sin(n.pulse)*.5+.5;
    ctx.beginPath(); ctx.arc(n.x,n.y,n.r+p,0,Math.PI*2);
    ctx.fillStyle=`rgba(62,207,173,${.25+p*.3})`; ctx.fill();
  });

  // Scroll new candle every ~90 frames
  if(frameCount%90===0){
    candles.shift(); candles.push(genCandle(candles[candles.length-1]));
    priceHistory.shift(); priceHistory.push(candles[candles.length-1].close);
  }

  requestAnimationFrame(drawFrame);
}

window.addEventListener('resize',()=>{ resize(); initNodes(); });

// Delay init to ensure layout is computed
window.addEventListener('load', () => { resize(); initNodes(); drawFrame(); });

/* ─── SCROLL REVEAL ─── */
const observer = new IntersectionObserver(entries => {
  entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); } });
}, { threshold: .12 });

document.querySelectorAll('.reveal').forEach(el => {
  observer.observe(el);
  if (el.closest('.hero')) {
    setTimeout(() => el.classList.add('visible'), 100);
  }
});
</script>
